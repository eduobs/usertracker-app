@page "/dashboard/users"
@model UserTracker.Pages.UsersModel
@{
    ViewData["Title"] = "Gerenciar Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-semibold mb-0">Gerenciar Usuários</h4>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Nome</th>
                    <th>E-mail</th>
                    <th>Papel</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="ps-4 fw-medium text-dark">@user.Name</td>
                        <td class="text-secondary">@user.Email</td>
                        <td>
                            @if(user.Role == UserTracker.Models.UserRole.Admin)
                            {
                                <span class="tag" style="background:#e8eaf6;color:#3949ab;">Admin</span>
                            }
                            else
                            {
                                <span class="tag" style="background:#f3f4f6;color:#4b5563;">Common</span>
                            }
                        </td>
                        <td>
                            @if (user.IsApproved)
                            {
                                <span class="tag" style="background:#e6f4ea;color:#1e8e3e;">Aprovado</span>
                            }
                            else
                            {
                                <span class="tag" style="background:#fef08a;color:#854d0e;">Pendente</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <form method="post" class="d-inline">
                                <input type="hidden" name="userId" value="@user.Id" />
                                @if (!user.IsApproved)
                                {
                                    <button type="submit" asp-page-handler="Approve" class="btn btn-sm btn-success">Aprovar</button>
                                }
                                
                                @if (user.Role == UserTracker.Models.UserRole.Common)
                                {
                                    <button type="submit" asp-page-handler="MakeAdmin" class="btn btn-sm btn-outline-primary ms-1">Tornar Admin</button>
                                }
                                else if (Model.CurrentUserEmail != user.Email)
                                {
                                    <button type="submit" asp-page-handler="MakeCommon" class="btn btn-sm btn-outline-secondary ms-1">Tornar Common</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
