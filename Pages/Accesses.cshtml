@page
@model UserTracker.Pages.AccessesModel
@{
    ViewData["Title"] = "Acessos";
}

<div class="mb-4 d-flex align-items-center justify-content-between">
    <div>
        <h4 class="fw-semibold mb-0">Todos os Acessos</h4>
        <span class="text-muted" style="font-size:12px;">Histórico completo de dispositivos rastreados</span>
    </div>
    <button id="btn-autoreload" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-repeat"></i> Auto-Reload: Desativado
    </button>
</div>

<!-- Filtros e Ações -->
<div class="table-card p-3 mb-3 d-flex gap-2 flex-wrap align-items-center">
    <input type="text" id="filter-ip" class="form-control form-control-sm" style="max-width:180px" placeholder="Filtrar por IP" />
    <input type="text" id="filter-hash" class="form-control form-control-sm" style="max-width:280px" placeholder="Filtrar por fingerprint hash" />
    <button class="btn btn-sm btn-primary" onclick="loadPage(1)">Filtrar</button>
    <button class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">Limpar</button>
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-success" onclick="exportToJson()">
            <i class="bi bi-download"></i> Exportar JSON
        </button>
        <button class="btn btn-sm btn-danger d-none" id="btn-delete-selected" onclick="deleteSelected()">
            <i class="bi bi-trash"></i> Excluir Selecionados
        </button>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:40px"><input class="form-check-input" type="checkbox" id="chk-all" onchange="toggleAll(this)"></th>
                    <th>#</th>
                    <th>Data/Hora</th>
                    <th>IP</th>
                    <th>Navegador</th>
                    <th>OS</th>
                    <th>Dispositivo</th>
                    <th>Tela</th>
                    <th>Timezone</th>
                    <th>Fingerprint</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="accesses-body"></tbody>
        </table>
    </div>
    <div class="p-3 d-flex align-items-center justify-content-between border-top">
        <span class="text-muted" id="page-info"></span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" id="btn-prev" onclick="changePage(-1)">← Anterior</button>
            <button class="btn btn-sm btn-outline-secondary" id="btn-next" onclick="changePage(1)">Próxima →</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentPage = 1;
const pageSize = 20;
let currentItems = [];

async function loadPage(page) {
    currentPage = page;
    const ip = document.getElementById('filter-ip').value;
    const hash = document.getElementById('filter-hash').value;
    const params = new URLSearchParams({ page, size: pageSize });
    if (ip) params.set('ip', ip);
    if (hash) params.set('hash', hash);

    const r = await fetch('/api/tracking/accesses?' + params);
    const d = await r.json();
    currentItems = d.items;

    const totalPages = Math.ceil(d.total / pageSize);
    document.getElementById('page-info').textContent =
        `Página ${page} de ${totalPages} (${d.total.toLocaleString()} registros)`;
    document.getElementById('btn-prev').disabled = page <= 1;
    document.getElementById('btn-next').disabled = page >= totalPages;

    document.getElementById('accesses-body').innerHTML = d.items.map(item => `
        <tr>
            <td><input class="form-check-input chk-item" type="checkbox" value="${item.id}" onchange="toggleItem()"></td>
            <td class="text-muted">${item.id}</td>
            <td style="white-space:nowrap">${new Date(item.accessedAt).toLocaleString('pt-BR')}</td>
            <td><code>${item.ipAddress}</code></td>
            <td>${item.browserFamily ?? '–'} ${item.browserVersion ?? ''}</td>
            <td>${item.osFamily ?? '–'}</td>
            <td><span class="tag ${item.isMobile ? 'tag-mobile' : 'tag-desktop'}">${item.isMobile ? '📱' : '🖥️'} ${item.deviceFamily ?? ''}</span></td>
            <td style="white-space:nowrap">${item.screenWidth ?? '–'}×${item.screenHeight ?? '–'}</td>
            <td style="font-size:12px">${item.timezone ?? '–'}</td>
            <td><span class="badge-hash">${(item.fingerprintHash || '').slice(0, 14)}…</span></td>
            <td>
                <a href="/accesses/${item.id}" class="btn btn-sm btn-outline-primary py-0">ver</a>
            </td>
        </tr>`).join('') || '<tr><td colspan="11" class="text-center text-muted py-3">Nenhum registro encontrado.</td></tr>';

    document.getElementById('chk-all').checked = false;
    if (typeof updateDeleteButton === 'function') updateDeleteButton();
}

function changePage(delta) {
    loadPage(currentPage + delta);
}

function clearFilters() {
    document.getElementById('filter-ip').value = '';
    document.getElementById('filter-hash').value = '';
    loadPage(1);
}

function toggleAll(source) {
    const checkboxes = document.querySelectorAll('.chk-item');
    checkboxes.forEach(chk => chk.checked = source.checked);
    updateDeleteButton();
}

function toggleItem() {
    const all = document.querySelectorAll('.chk-item');
    const checked = document.querySelectorAll('.chk-item:checked');
    document.getElementById('chk-all').checked = all.length > 0 && all.length === checked.length;
    updateDeleteButton();
}

function updateDeleteButton() {
    const checked = document.querySelectorAll('.chk-item:checked');
    const btn = document.getElementById('btn-delete-selected');
    if (checked.length > 0) {
        btn.classList.remove('d-none');
        btn.innerHTML = `<i class="bi bi-trash"></i> Excluir Selecionados (${checked.length})`;
    } else {
        btn.classList.add('d-none');
    }
}

async function deleteSelected() {
    const checked = document.querySelectorAll('.chk-item:checked');
    if (checked.length === 0) return;
    
    if (!confirm(`Tem certeza que deseja excluir ${checked.length} registro(s)?`)) return;

    const ids = Array.from(checked).map(chk => parseInt(chk.value));

    const response = await fetch('/api/tracking/accesses/batch-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(ids)
    });

    if (response.ok) {
        loadPage(currentPage);
    } else {
        alert('Erro ao excluir os registros.');
    }
}

async function exportToJson() {
    const checked = document.querySelectorAll('.chk-item:checked');
    if (checked.length === 0) {
        alert('Por favor, selecione os registros que deseja exportar.');
        return;
    }
    
    const ids = Array.from(checked).map(chk => parseInt(chk.value));
    const dataToExport = currentItems.filter(item => ids.includes(item.id));

    try {
        // Formata os dados selecionados para o JSON de forma legível
        const jsonStr = JSON.stringify(dataToExport, null, 2);
        
        // Cria um "arquivo virtual" com o texto
        const blob = new Blob([jsonStr], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        
        // Dispara o download criando um link invisível
        const a = document.createElement('a');
        a.href = url;
        a.download = `selecionados_acessos_${new Date().toISOString().slice(0,10)}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    } catch (e) {
        alert("Erro ao exportar dados.");
        console.error(e);
    }
}

loadPage(1);

let reloadInterval = null;
let isReloading = false;

document.getElementById('btn-autoreload').addEventListener('click', (e) => {
    const btn = e.currentTarget;
    if (isReloading) {
        clearInterval(reloadInterval);
        isReloading = false;
        btn.classList.replace('btn-primary', 'btn-outline-secondary');
        btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Auto-Reload: Desativado';
    } else {
        loadPage(1);
        reloadInterval = setInterval(() => { loadPage(1); }, 15000);
        isReloading = true;
        btn.classList.replace('btn-outline-secondary', 'btn-primary');
        btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Auto-Reload: Ativado';
    }
});
</script>
}
